{
  "dashboard": {
    "id": null,
    "title": "Security & Compliance Metrics",
    "tags": ["security", "compliance", "vulnerabilities"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Critical Vulnerabilities",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(vulnerability_count{severity=\"critical\"})",
            "legendFormat": "Critical"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "red", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "High Vulnerabilities",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(vulnerability_count{severity=\"high\"})",
            "legendFormat": "High"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Security Scan Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "(sum(rate(security_scan_total{status=\"success\"}[1h])) / sum(rate(security_scan_total[1h]))) * 100",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 90},
                {"color": "green", "value": 98}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Compliance Score",
        "type": "stat",
        "targets": [
          {
            "expr": "compliance_score_percentage",
            "legendFormat": "Compliance"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 80},
                {"color": "green", "value": 95}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Vulnerability Trends",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (severity) (vulnerability_count)",
            "legendFormat": "{{severity}}"
          }
        ],
        "yAxes": [
          {
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "Security Incidents",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(security_incident_total[1h]))",
            "legendFormat": "Incidents/hour"
          }
        ],
        "yAxes": [
          {
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Secret Detection Events",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (type) (rate(secret_detection_total[1h]))",
            "legendFormat": "{{type}}"
          }
        ],
        "yAxes": [
          {
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "Container Security Scans",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (status) (rate(container_scan_total[1h]))",
            "legendFormat": "{{status}}"
          }
        ],
        "yAxes": [
          {
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 9,
        "title": "Dependency Vulnerabilities by Project",
        "type": "table",
        "targets": [
          {
            "expr": "sum by (project, severity) (dependency_vulnerability_count)",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true
              },
              "renameByName": {
                "project": "Project",
                "severity": "Severity",
                "Value": "Count"
              }
            }
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 10,
        "title": "Security Policy Violations",
        "type": "table",
        "targets": [
          {
            "expr": "sum by (policy, project) (policy_violation_count)",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true
              },
              "renameByName": {
                "policy": "Policy",
                "project": "Project",
                "Value": "Violations"
              }
            }
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 11,
        "title": "Mean Time to Remediation",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(vulnerability_remediation_time_seconds)",
            "legendFormat": "MTTR"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 86400},
                {"color": "red", "value": 604800}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 32}
      },
      {
        "id": 12,
        "title": "Security Training Completion",
        "type": "stat",
        "targets": [
          {
            "expr": "(sum(security_training_completed) / sum(security_training_required)) * 100",
            "legendFormat": "Completion Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 80},
                {"color": "green", "value": 95}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 32}
      },
      {
        "id": 13,
        "title": "Audit Log Events",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(audit_log_events_total[1h]))",
            "legendFormat": "Events/hour"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 32}
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "5m"
  }
}