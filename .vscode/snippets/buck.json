{
  "Buck2 Rust Binary": {
    "prefix": "rust_binary",
    "body": [
      "rust_binary(",
      "    name = \"${1:binary_name}\",",
      "    srcs = [\"${2:src/main.rs}\"],",
      "    deps = [",
      "        ${3:# Add dependencies here}",
      "    ],",
      "    edition = \"2021\",",
      "    visibility = [\"PUBLIC\"],",
      ")"
    ],
    "description": "Create a Buck2 Rust binary rule"
  },
  "Buck2 Rust Library": {
    "prefix": "rust_library",
    "body": [
      "rust_library(",
      "    name = \"${1:library_name}\",",
      "    srcs = glob([\"src/**/*.rs\"]),",
      "    deps = [",
      "        ${2:# Add dependencies here}",
      "    ],",
      "    edition = \"2021\",",
      "    visibility = [\"PUBLIC\"],",
      ")"
    ],
    "description": "Create a Buck2 Rust library rule"
  },
  "Buck2 Rust Test": {
    "prefix": "rust_test",
    "body": [
      "rust_test(",
      "    name = \"${1:test_name}\",",
      "    srcs = [\"${2:tests/test.rs}\"],",
      "    deps = [",
      "        \":${3:library_name}\",",
      "        ${4:# Add test dependencies here}",
      "    ],",
      "    edition = \"2021\",",
      ")"
    ],
    "description": "Create a Buck2 Rust test rule"
  },
