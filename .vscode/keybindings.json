[
  // Buck2 build shortcuts
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.tasks.runTask",
    "args": "Buck2: Build All"
  },
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.tasks.runTask",
    "args": "Buck2: Test All"
  },
  
  // Rust-specific shortcuts
  {
    "key": "ctrl+shift+r",
    "command": "workbench.action.tasks.runTask",
    "args": "Rust: Check All"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.tasks.runTask",
    "args": "Format All Code"
  },
  
  // Testing shortcuts
  {
    "key": "ctrl+shift+u",
    "command": "workbench.action.tasks.runTask",
    "args": "Rust: Test with Nextest"
  },
  {
    "key": "ctrl+shift+p",
    "command": "workbench.action.tasks.runTask",
    "args": "Run Performance Tests"
  },
  
  // Security shortcuts
  {
    "key": "ctrl+shift+s",
    "command": "workbench.action.tasks.runTask",
    "args": "Run All Security Checks"
  },
  
  // Documentation shortcuts
  {
    "key": "ctrl+shift+d",
    "command": "workbench.action.tasks.runTask",
    "args": "Generate Documentation"
  },
  
  // Navigation shortcuts
  {
    "key": "ctrl+shift+o",
    "command": "workbench.action.quickOpen",
    "args": "@"
  },
  {
    "key": "ctrl+shift+;",
    "command": "workbench.action.showCommands"
  },
  
  // Terminal shortcuts
  {
    "key": "ctrl+shift+`",
    "command": "workbench.action.terminal.new"
  },
  {
    "key": "ctrl+shift+c",
    "command": "workbench.action.terminal.openNativeConsole"
  },
  
  // File navigation
  {
    "key": "ctrl+shift+e",
    "command": "workbench.view.explorer"
  },
  {
    "key": "ctrl+shift+g",
    "command": "workbench.view.scm"
  },
  
  // Debug shortcuts
  {
    "key": "f5",
    "command": "workbench.action.debug.start"
  },
  {
    "key": "shift+f5",
    "command": "workbench.action.debug.stop"
  },
  {
    "key": "f9",
    "command": "editor.debug.action.toggleBreakpoint"
  },
  {
    "key": "f10",
    "command": "workbench.action.debug.stepOver"
  },
  {
    "key": "f11",
    "command": "workbench.action.debug.stepInto"
  },
  {
    "key": "shift+f11",
    "command": "workbench.action.debug.stepOut"
  },
  
  // Code actions
  {
    "key": "ctrl+.",
    "command": "editor.action.quickFix"
  },
  {
    "key": "alt+enter",
    "command": "editor.action.quickFix"
  },
  {
    "key": "ctrl+shift+i",
    "command": "editor.action.formatDocument"
  },
  
  // Search and replace
  {
    "key": "ctrl+shift+h",
    "command": "workbench.action.replaceInFiles"
  },
  {
    "key": "ctrl+shift+j",
    "command": "workbench.action.search.toggleQueryDetails"
  },
  
  // Git shortcuts
  {
    "key": "ctrl+shift+g g",
    "command": "git.openChange"
  },
  {
    "key": "ctrl+shift+g s",
    "command": "git.stage"
  },
  {
    "key": "ctrl+shift+g u",
    "command": "git.unstage"
  },
  {
    "key": "ctrl+shift+g c",
    "command": "git.commit"
  },
  {
    "key": "ctrl+shift+g p",
    "command": "git.push"
  },
  
  // Workspace shortcuts
  {
    "key": "ctrl+k ctrl+o",
    "command": "workbench.action.files.openFolder"
  },
  {
    "key": "ctrl+k ctrl+w",
    "command": "workbench.action.closeAllEditors"
  },
  
  // Custom task shortcuts
  {
    "key": "ctrl+alt+h",
    "command": "workbench.action.tasks.runTask",
    "args": "Health Check"
  },
  {
    "key": "ctrl+alt+s",
    "command": "workbench.action.tasks.runTask",
    "args": "Setup Development Environment"
  },
  {
    "key": "ctrl+alt+c",
    "command": "workbench.action.tasks.runTask",
    "args": "Clean All Build Artifacts"
  }
]